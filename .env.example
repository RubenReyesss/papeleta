# URL de Ollama (instalado localmente en Windows)
OLLAMA_HOST=http://localhost:11434

# Modelo a usar — debe estar descargado con: ollama pull gemma4:e4b
MODEL_NAME=gemma4:e4b

# Ruta del historial SQLite (se crea automaticamente)
DB_PATH=./history.db

# Tamano maximo de fichero subido en megabytes
MAX_FILE_MB=20

# Puerto del backend
PORT=8000
